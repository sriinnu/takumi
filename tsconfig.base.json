{
	"compilerOptions": {
		"target": "ES2024",
		"module": "NodeNext",
		"lib": ["ES2024"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"declaration": true,
		"declarationMap": false,
		"sourceMap": false,
		"inlineSources": false,
		"inlineSourceMap": false,
		"moduleResolution": "NodeNext",
		"resolveJsonModule": true,
		"allowImportingTsExtensions": false,
		"types": ["node"]
	},
	"exclude": ["node_modules", "dist", "dist-bin", "tmp", "coverage"]
}
