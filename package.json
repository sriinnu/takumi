{
	"name": "takumi",
	"private": true,
	"type": "module",
	"version": "0.1.0",
	"license": "MIT",
	"description": "Terminal UI for AI coding agents — reactive rendering, double-buffered output, and agent orchestration",
	"keywords": [
		"ai",
		"tui",
		"terminal",
		"agent",
		"typescript",
		"cli",
		"coding-agent",
		"reactive"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/sriinnu/takumi.git"
	},
	"scripts": {
		"build": "pnpm -r run build",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"clean": "pnpm -r run clean",
		"nuke": "node -e \"const fs=require('fs');const p=require('path');['node_modules',...require('fs').readdirSync('packages').map(d=>p.join('packages',d,'node_modules'))].forEach(d=>{try{fs.rmSync(d,{recursive:true,force:true});console.log('removed',d)}catch{}})\"",
		"fresh": "pnpm run nuke && pnpm install && pnpm build",
		"dev": "pnpm -r --parallel run dev",
		"check": "biome check --write --error-on-warnings .",
		"takumi": "tsx bin/takumi.ts",
		"prepare": "husky"
	},
	"dependencies": {
		"@clack/prompts": "^1.0.1",
		"@takumi/agent": "workspace:*",
		"@takumi/core": "workspace:*",
		"@takumi/tui": "workspace:*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.14",
		"@types/node": "^22.0.0",
		"husky": "^9.0.0",
		"lint-staged": "^15.0.0",
		"tsx": "^4.21.0",
		"typescript": "^5.7.0",
		"vitest": "^4.0.18"
	},
	"engines": {
		"node": ">=22"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"lint-staged": {
		"*.{ts,tsx}": [
			"biome check --write --no-errors-on-unmatched"
		]
	}
}
