{
	"name": "takumi",
	"type": "module",
	"version": "0.1.0",
	"license": "MIT",
	"description": "Terminal UI for AI coding agents — reactive rendering, double-buffered output, and agent orchestration",
	"keywords": [
		"ai",
		"tui",
		"terminal",
		"agent",
		"typescript",
		"cli",
		"coding-agent",
		"reactive"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/sriinnu/takumi.git"
	},
	"bin": {
		"takumi": "dist/takumi.cjs",
		"takumi-telemetry-snapshot": "./bin/telemetry-snapshot.ts"
	},
	"files": [
		"dist/",
		"bin/",
		"docs/",
		"packages/core/src/",
		"packages/core/dist/",
		"packages/render/src/",
		"packages/render/dist/",
		"packages/bridge/src/",
		"packages/bridge/dist/",
		"packages/agent/src/",
		"packages/agent/dist/",
		"packages/tui/src/",
		"packages/tui/dist/",
		"examples/packages/",
		"README.md"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "pnpm -r run build",
		"bundle": "node scripts/bundle.mjs",
		"bundle:watch": "node scripts/bundle.mjs --watch",
		"prepublishOnly": "pnpm build && pnpm bundle",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"clean": "pnpm -r run clean && rm -rf dist",
		"nuke": "node -e \"const fs=require('fs');const p=require('path');['node_modules',...require('fs').readdirSync('packages').map(d=>p.join('packages',d,'node_modules'))].forEach(d=>{try{fs.rmSync(d,{recursive:true,force:true});console.log('removed',d)}catch{}})\"",
		"fresh": "pnpm run nuke && pnpm install && pnpm build",
		"dev": "pnpm -r --parallel run dev",
		"check:loc": "node scripts/guard-loc.mjs",
		"check": "pnpm run check:loc && biome check --write --error-on-warnings .",
		"takumi": "tsx bin/takumi.ts",
		"eval": "tsx scripts/eval.ts",
		"prepare": "husky"
	},
	"dependencies": {
		"@clack/prompts": "^1.0.1",
		"@takumi/agent": "workspace:*",
		"@takumi/bridge": "workspace:*",
		"@takumi/core": "workspace:*",
		"@takumi/tui": "workspace:*",
		"kosha-discovery": "^0.3.0",
		"tsx": "^4.21.0",
		"yoga-wasm-web": "^0.3.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.14",
		"@types/node": "^22.0.0",
		"esbuild": "^0.25.0",
		"husky": "^9.0.0",
		"lint-staged": "^15.0.0",
		"typescript": "^5.7.0",
		"vitest": "^4.0.18"
	},
	"engines": {
		"node": ">=22"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		],
		"ignoredBuiltDependencies": [
			"better-sqlite3"
		]
	},
	"lint-staged": {
		"*.{ts,tsx}": [
			"biome check --write --no-errors-on-unmatched"
		]
	}
}
