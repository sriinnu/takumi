{
	"name": "@takumi/bridge",
	"version": "0.1.0",
	"description": "Integration bridge — Chitragupta MCP client, Darpana proxy client, and Git helpers",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/sriinnu/takumi.git",
		"directory": "packages/bridge"
	},
	"engines": {
		"node": ">=22"
	},
	"publishConfig": {
		"access": "public"
	},
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./*": {
			"types": "./dist/*.d.ts",
			"import": "./dist/*.js"
		}
	},
	"scripts": {
		"build": "rm -rf dist && tsc -p tsconfig.json",
		"dev": "tsc -p tsconfig.json --watch",
		"clean": "rm -rf dist"
	},
	"files": [
		"dist",
		"README.md"
	],
	"dependencies": {
		"@fastify/cors": "^11.2.0",
		"@fastify/rate-limit": "^10.3.0",
		"@takumi/core": "workspace:*",
		"fastify": "^5.7.4"
	}
}
