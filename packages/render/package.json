{
	"name": "@takumi/render",
	"version": "0.1.0",
	"description": "Reactive terminal rendering engine with signals, double-buffer, Yoga layout, and component system",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/sriinnu/takumi.git",
		"directory": "packages/render"
	},
	"engines": {
		"node": ">=22"
	},
	"publishConfig": {
		"access": "public"
	},
	"main": "dist/index.js",
	"types": "src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./dist/index.js"
		},
		"./*": {
			"types": "./dist/*.d.ts",
			"import": "./dist/*.js"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"dev": "tsc -p tsconfig.json --watch",
		"clean": "rm -rf dist"
	},
	"files": [
		"src",
		"dist",
		"README.md"
	],
	"dependencies": {
		"@takumi/core": "workspace:*",
		"yoga-wasm-web": "^0.3.3"
	}
}
